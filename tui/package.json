{
  "name": "compass-tui",
  "private": true,
  "version": "0.1.0",
  "description": "Companion terminal monitor for claude-compass — live view of the guard's blocks and warns (the log you'd otherwise tail -f)",
  "type": "module",
  "bin": {
    "compass-tui": "dist/cli.js"
  },
  "scripts": {
