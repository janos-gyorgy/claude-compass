    "start": "node dist/cli.js",
    "test": "tsc && node --test dist/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
