{
  "name": "claude-compass-ts",
  "private": true,
  "version": "1.0.0",
  "description": "TypeScript port of claude-compass; builds to a single committed dist/compass.mjs (run with bare node, no install)",
  "type": "module",
  "scripts": {
    "build": "esbuild src/compass.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/compass.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "esbuild": "^0.24.0",
    "smol-toml": "^1.3.1",
    "typescript": "^5.6.0"
  }
}
