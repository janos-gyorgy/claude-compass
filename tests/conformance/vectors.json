   }
  },
  {
   "name": "flagged-feature-branch-push-ok",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "git push -q --tags origin my-feature"
    }
   },
   "config": "[git_safety]\nenabled = true\n",
   "expect": {
